{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./runtime",
    "declaration": false,
    "incremental": false
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "runtime",
    "test",
    "**/*spec.ts",
    "prisma/seed.ts",
    "prisma.config.ts"
  ]
}
